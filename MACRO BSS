-- ===== VOTING/SKIP DETECTION FUNCTIONS =====
local function contains_voting_keyword(str)
    if type(str) ~= "string" then return false end
    local lower = string.lower(str)
    return string.find(lower, "vote") or 
           string.find(lower, "voting") or 
           string.find(lower, "skip") or
           string.find(lower, "kick") or
           string.find(lower, "yes") or
           string.find(lower, "no") or
           string.find(lower, "approve") or
           string.find(lower, "deny") or
           string.find(lower, "start") or
           string.find(lower, "end")
end

local function check_args_for_voting(args)
    local found_voting = false
    local voting_args = {}
    
    for i, arg in ipairs(args) do
        if type(arg) == "string" then
            if contains_voting_keyword(arg) then
                found_voting = true
                table.insert(voting_args, {index = i, value = arg})
            end
        elseif type(arg) == "table" then
            for k, v in pairs(arg) do
                if type(k) == "string" and contains_voting_keyword(k) then
                    found_voting = true
                    table.insert(voting_args, {index = i, key = k, value = v})
                end
                if type(v) == "string" and contains_voting_keyword(v) then
                    found_voting = true
                    table.insert(voting_args, {index = i, key = k, value = v})
                end
            end
        end
    end
    
    return found_voting, voting_args
end

local function serialize_argument(arg)
    local arg_type = typeof(arg)
    
    if arg_type == "string" then
        return string.format("%q", arg)
    elseif arg_type == "number" then
        return tostring(arg)
    elseif arg_type == "boolean" then
        return tostring(arg)
    elseif arg_type == "table" then
        local success, json = pcall(http_service.JSONEncode, http_service, arg)
        if success then
            return json
        else
            local table_str = "{"
            local items = {}
            for k, v in pairs(arg) do
                if type(k) == "string" then
                    table.insert(items, string.format("[%q]=%s", k, serialize_argument(v)))
                else
                    table.insert(items, string.format("[%s]=%s", tostring(k), serialize_argument(v)))
                end
            end
            table_str = table_str .. table.concat(items, ", ") .. "}"
            return table_str
        end
    elseif arg_type == "Vector3" then
        return string.format('Vector3.new(%.3f, %.3f, %.3f)', arg.X, arg.Y, arg.Z)
    elseif arg_type == "Vector2" then
        return string.format('Vector2.new(%.3f, %.3f)', arg.X, arg.Y)
    elseif arg_type == "CFrame" then
        local p = arg.Position
        return string.format('CFrame.new(%.3f, %.3f, %.3f)', p.X, p.Y, p.Z)
    elseif arg_type == "Color3" then
        return string.format('Color3.new(%.3f, %.3f, %.3f)', arg.R, arg.G, arg.B)
    elseif arg_type == "BrickColor" then
        return string.format('BrickColor.new("%s")', arg.Name)
    elseif arg_type == "UDim2" then
        return string.format('UDim2.new(%.3f, %d, %.3f, %d)', arg.X.Scale, arg.X.Offset, arg.Y.Scale, arg.Y.Offset)
    elseif arg_type == "UDim" then
        return string.format('UDim.new(%.3f, %d)', arg.Scale, arg.Offset)
    elseif arg_type == "EnumItem" then
        return string.format('Enum.%s.%s', arg.EnumType.Name, arg.Name)
    else
        return "nil"
    end
end

-- ===== HOOK INTO SIMPLESPY'S REMOTE DETECTION =====
local function hook_simplespy_remote_detection()
    -- Wait for SimpleSpy to be fully loaded
    local simplespy_loaded = false
    local max_attempts = 50
    local attempts = 0
    
    while not simplespy_loaded and attempts < max_attempts do
        if _G.SimpleSpyExecuted and SimpleSpy then
            simplespy_loaded = true
            break
        end
        task.wait(0.1)
        attempts = attempts + 1
    end
    
    if not simplespy_loaded then
        add_log("SimpleSpy not detected - using direct hook method")
        return false
    end
    
    add_log("SimpleSpy detected - hooking into remote detection")
    
    -- Store original functions
    local original_newRemote = newRemote
    local original_remoteHandler = remoteHandler
    
    -- Hook newRemote
    newRemote = function(type, name, args, remote, function_info, blocked, src, returnValue)
        local has_voting, voting_args = check_args_for_voting(args)
        
        if has_voting and _G.record_strat then
            local arg_strings = {}
            for i, arg in ipairs(args) do
                arg_strings[i] = serialize_argument(arg)
            end
            
            local command = string.format('TDS:RemoteCall("%s", %s)', 
                name,
                table.concat(arg_strings, ", ")
            )
            record_action(command)
            
            local voting_info = {}
            for _, va in ipairs(voting_args) do
                if va.key then
                    table.insert(voting_info, string.format("%q=%q", va.key, va.value))
                else
                    table.insert(voting_info, string.format("[%d]=%q", va.index, va.value))
                end
            end
            add_log(string.format("VOTE/SKIP [SimpleSpy] %s: %s", name, table.concat(voting_info, ", ")))
        end
        
        if original_newRemote then
            return original_newRemote(type, name, args, remote, function_info, blocked, src, returnValue)
        end
    end
    
    -- Hook remoteHandler
    remoteHandler = function(hookfunction, methodName, remote, args, funcInfo, calling, returnValue)
        local has_voting, voting_args = check_args_for_voting(args)
        local remote_name = pcall(function() return remote.Name end) and remote.Name or "Unknown"
        
        if has_voting and _G.record_strat then
            local arg_strings = {}
            for i, arg in ipairs(args) do
                arg_strings[i] = serialize_argument(arg)
            end
            
            local command = string.format('TDS:RemoteCall("%s", %s)', 
                remote_name,
                table.concat(arg_strings, ", ")
            )
            record_action(command)
            
            local voting_info = {}
            for _, va in ipairs(voting_args) do
                if va.key then
                    table.insert(voting_info, string.format("%q=%q", va.key, va.value))
                else
                    table.insert(voting_info, string.format("[%d]=%q", va.index, va.value))
                end
            end
            add_log(string.format("VOTE/SKIP [SimpleSpy] %s.%s: %s", remote_name, methodName, table.concat(voting_info, ", ")))
        end
        
        if original_remoteHandler then
            return original_remoteHandler(hookfunction, methodName, remote, args, funcInfo, calling, returnValue)
        end
    end
    
    -- Also hook into SimpleSpy's signal system
    if SimpleSpy.GetRemoteFiredSignal then
        local function hook_remote_signal(remote)
            if not remote:IsA("RemoteFunction") and not remote:IsA("RemoteEvent") then return end
            
            local signal = SimpleSpy:GetRemoteFiredSignal(remote)
            signal:Connect(function(args)
                if not _G.record_strat then return end
                
                local has_voting, voting_args = check_args_for_voting(args)
                if has_voting then
                    local remote_name = pcall(function() return remote.Name end) and remote.Name or "Unknown"
                    local arg_strings = {}
                    for i, arg in ipairs(args) do
                        arg_strings[i] = serialize_argument(arg)
                    end
                    
                    local command = string.format('TDS:RemoteCall("%s", %s)', 
                        remote_name,
                        table.concat(arg_strings, ", ")
                    )
                    record_action(command)
                    add_log(string.format("VOTE/SKIP [Signal] %s: %d args", remote_name, #args))
                end
            end)
        end
        
        -- Hook existing remotes
        for _, child in ipairs(replicated_storage:GetDescendants()) do
            if child:IsA("RemoteFunction") or child:IsA("RemoteEvent") then
                hook_remote_signal(child)
            end
        end
        
        -- Hook future remotes
        replicated_storage.DescendantAdded:Connect(function(child)
            if child:IsA("RemoteFunction") or child:IsA("RemoteEvent") then
                hook_remote_signal(child)
            end
        end)
    end
    
    return true
end

-- ===== DIRECT REMOTE HOOKING (FALLBACK) =====
local function setup_direct_remote_hooks()
    add_log("Setting up direct remote hooks (fallback)")
    
    local function hook_remote_function(remote)
        if not remote:IsA("RemoteFunction") then return end
        
        local remote_name = remote.Name
        local original_invoke = remote.InvokeServer
        
        remote.InvokeServer = function(self, ...)
            local args = {...}
            local has_voting, voting_args = check_args_for_voting(args)
            
            if has_voting and _G.record_strat then
                local arg_strings = {}
                for i, arg in ipairs(args) do
                    arg_strings[i] = serialize_argument(arg)
                end
                
                local command = string.format('TDS:RemoteCall("%s", %s)', 
                    remote_name,
                    table.concat(arg_strings, ", ")
                )
                record_action(command)
                
                local voting_info = {}
                for _, va in ipairs(voting_args) do
                    if va.key then
                        table.insert(voting_info, string.format("%q=%q", va.key, va.value))
                    else
                        table.insert(voting_info, string.format("[%d]=%q", va.index, va.value))
                    end
                end
                add_log(string.format("VOTE/SKIP [Direct] %s: %s", remote_name, table.concat(voting_info, ", ")))
            end
            
            return original_invoke(self, ...)
        end
    end
    
    -- Hook existing RemoteFunctions
    for _, child in ipairs(replicated_storage:GetDescendants()) do
        if child:IsA("RemoteFunction") then
            hook_remote_function(child)
        end
    end
    
    -- Hook future RemoteFunctions
    replicated_storage.DescendantAdded:Connect(function(child)
        if child:IsA("RemoteFunction") then
            hook_remote_function(child)
        end
    end)
end

