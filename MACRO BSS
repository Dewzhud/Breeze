-- ===== REMOTE FUNCTION HOOKING (INVOKE SERVER ONLY) =====
local hooked_remotes = {}

local function contains_voting_keyword(str)
    if type(str) ~= "string" then return false end
    local lower = string.lower(str)
    return string.find(lower, "vote") or 
           string.find(lower, "voting") or 
           string.find(lower, "skip") or
           string.find(lower, "kick") or
           string.find(lower, "yes") or
           string.find(lower, "no") or
           string.find(lower, "approve") or
           string.find(lower, "deny")
end

local function check_args_for_voting(...)
    local args = {...}
    local found_voting = false
    
    for _, arg in ipairs(args) do
        if type(arg) == "string" then
            if contains_voting_keyword(arg) then
                found_voting = true
                break
            end
        elseif type(arg) == "table" then
            for k, v in pairs(arg) do
                if type(k) == "string" and contains_voting_keyword(k) then
                    found_voting = true
                    break
                end
                if type(v) == "string" and contains_voting_keyword(v) then
                    found_voting = true
                    break
                end
            end
        end
    end
    
    return found_voting
end

local function serialize_argument(arg)
    local arg_type = typeof(arg)
    
    if arg_type == "string" then
        return string.format("%q", arg)
    elseif arg_type == "number" then
        return tostring(arg)
    elseif arg_type == "boolean" then
        return tostring(arg)
    elseif arg_type == "table" then
        local success, json = pcall(http_service.JSONEncode, http_service, arg)
        if success then
            return json
        else
            local table_str = "{"
            local items = {}
            for k, v in pairs(arg) do
                if type(k) == "string" then
                    table.insert(items, string.format("[%q]=%s", k, serialize_argument(v)))
                else
                    table.insert(items, string.format("[%s]=%s", tostring(k), serialize_argument(v)))
                end
            end
            table_str = table_str .. table.concat(items, ", ") .. "}"
            return table_str
        end
    elseif arg_type == "Vector3" then
        return string.format('Vector3.new(%.3f, %.3f, %.3f)', arg.X, arg.Y, arg.Z)
    elseif arg_type == "Vector2" then
        return string.format('Vector2.new(%.3f, %.3f)', arg.X, arg.Y)
    elseif arg_type == "CFrame" then
        local p = arg.Position
        return string.format('CFrame.new(%.3f, %.3f, %.3f)', p.X, p.Y, p.Z)
    elseif arg_type == "Color3" then
        return string.format('Color3.new(%.3f, %.3f, %.3f)', arg.R, arg.G, arg.B)
    elseif arg_type == "BrickColor" then
        return string.format('BrickColor.new("%s")', arg.Name)
    elseif arg_type == "UDim2" then
        return string.format('UDim2.new(%.3f, %d, %.3f, %d)', arg.X.Scale, arg.X.Offset, arg.Y.Scale, arg.Y.Offset)
    elseif arg_type == "UDim" then
        return string.format('UDim.new(%.3f, %d)', arg.Scale, arg.Offset)
    elseif arg_type == "EnumItem" then
        return string.format('Enum.%s.%s', arg.EnumType.Name, arg.Name)
    else
        return "nil"
    end
end

-- Hook RemoteFunction.InvokeServer
local function hook_remote_function(remote)
    if not remote:IsA("RemoteFunction") then return end
    if hooked_remotes[remote] then return end
    
    local remote_name = remote.Name
    local original_invoke = remote.InvokeServer
    
    -- Override InvokeServer method
    remote.InvokeServer = function(self, ...)
        local args = {...}
        
        -- Check if any argument contains voting/skip keywords
        local has_voting = check_args_for_voting(...)
        
        if has_voting and _G.record_strat then
            local arg_strings = {}
            for i, arg in ipairs(args) do
                arg_strings[i] = serialize_argument(arg)
            end
            
            local command = string.format('TDS:RemoteCall("%s", %s)', 
                remote_name,
                table.concat(arg_strings, ", ")
            )
            record_action(command)
            add_log(string.format("VOTE/SKIP Invoke: %s (%d args)", remote_name, #args))
            
            -- Print args for debugging
            for i, arg in ipairs(args) do
                if type(arg) == "string" and contains_voting_keyword(arg) then
                    add_log(string.format("  Found voting keyword in arg %d: %q", i, arg))
                end
            end
        end
        
        -- Call original InvokeServer
        return original_invoke(self, ...)
    end
    
    hooked_remotes[remote] = true
    add_log("Hooked RemoteFunction: " .. remote_name .. ".InvokeServer")
end

-- Hook existing RemoteFunctions
local function hook_all_remote_functions()
    for _, child in ipairs(replicated_storage:GetChildren()) do
        if child:IsA("RemoteFunction") then
            hook_remote_function(child)
        elseif child:IsA("Folder") or child:IsA("Model") then
            -- Scan subfolders for RemoteFunctions
            for _, subchild in ipairs(child:GetChildren()) do
                if subchild:IsA("RemoteFunction") then
                    hook_remote_function(subchild)
                end
            end
        end
    end
end

-- Hook future RemoteFunctions
replicated_storage.ChildAdded:Connect(function(child)
    if child:IsA("RemoteFunction") then
        hook_remote_function(child)
    elseif child:IsA("Folder") or child:IsA("Model") then
        child.ChildAdded:Connect(function(subchild)
            if subchild:IsA("RemoteFunction") then
                hook_remote_function(subchild)
            end
        end)
        -- Also check existing children
        for _, subchild in ipairs(child:GetChildren()) do
            if subchild:IsA("RemoteFunction") then
                hook_remote_function(subchild)
            end
        end
    end
end)

-- Initialize hooks
hook_all_remote_functions()

-- ===== START RECORDING =====
start_btn.MouseButton1Click:Connect(function()
    local current_mode = "Unknown"
    local current_map = "Unknown"
    
    local state_folder = replicated_storage:FindFirstChild("State")
    if state_folder then
        current_mode = state_folder.Difficulty.Value
        current_map = state_folder.Map.Value
    end

    local tower1, tower2, tower3, tower4, tower5 = "None", "None", "None", "None", "None"
    local current_modifiers = "" 
    local state_replicators = replicated_storage:FindFirstChild("StateReplicators")

    if state_replicators then
        for _, folder in ipairs(state_replicators:GetChildren()) do
            if folder.Name == "PlayerReplicator" and folder:GetAttribute("UserId") == player.UserId then
                local equipped = folder:GetAttribute("EquippedTowers")
                if type(equipped) == "string" then
                    local cleaned_json = equipped:match("%[.*%]") 
                    
                    local success, tower_table = pcall(function()
                        return http_service:JSONDecode(cleaned_json)
                    end)

                    if success and type(tower_table) == "table" then
                        tower1 = tower_table[1] or "None"
                        tower2 = tower_table[2] or "None"
                        tower3 = tower_table[3] or "None"
                        tower4 = tower_table[4] or "None"
                        tower5 = tower_table[5] or "None"
                    end
                end
            end

            if folder.Name == "ModifierReplicator" then
                local raw_votes = folder:GetAttribute("Votes")
                if type(raw_votes) == "string" then
                    local cleaned_json = raw_votes:match("{.*}") 
                    
                    local success, mod_table = pcall(function()
                        return http_service:JSONDecode(cleaned_json)
                    end)

                    if success and type(mod_table) == "table" then
                        local mods = {}
                        for mod_name, _ in pairs(mod_table) do
                            table.insert(mods, mod_name .. " = true")
                        end
                        current_modifiers = table.concat(mods, ", ")
                    end
                end
            end
        end
    end

    _G.record_strat = true
    for _, child in ipairs(log_box:GetChildren()) do
        if child:IsA("TextLabel") then child:Destroy() end
    end

    add_log("Mode: " .. current_mode)
    add_log("Map: " .. current_map)
    add_log("Towers: " .. tower1 .. ", " .. tower2)
    add_log(tower3 .. ", " .. tower4 .. ", " .. tower5)
    add_log("--- Recording Started (Voting/Skip RemoteFunction.InvokeServer only) ---")
    add_log("Watching for: vote, voting, skip, kick, yes, no, approve, deny")
    
    if writefile then 
        local config_header = string.format([[
local TDS = loadstring(game:HttpGet("https://raw.githubusercontent.com/DuxiiT/auto-strat/refs/heads/main/Library.lua"))()

TDS:Loadout("%s", "%s", "%s", "%s", "%s")
TDS:Mode("%s")
TDS:GameInfo("%s", {%s})

-- Voting/Skip RemoteFunction.InvokeServer calls will be recorded below
-- Format: TDS:RemoteCall("RemoteName", arg1, arg2, ...)

]], tower1, tower2, tower3, tower4, tower5, current_mode, current_map, current_modifiers)

        writefile(file_name, config_header)
        add_log("Created Strat.txt file with header")
    end
end)

